class Solution {
    public int maxScore(int[] arr, int k) {
        int n = arr.length;
        int totalSum =0;
        for(int i =0; i<n; i++){
            totalSum+=arr[i];
        }
        int windowSize = n-k;
        //sum for the firstWindow;
        int windowSum=0;
        for(int i =0; i<n-k; i++){
            windowSum +=arr[i];
        }
        int minSum = windowSum; 
        //sliding window
        for(int i= n-k; i<n; i++ ){
            windowSum = windowSum - arr[i-windowSize];
            windowSum = windowSum + arr[i];
            minSum = Math.min(minSum, windowSum);
        }
        return totalSum - minSum;
    }
}
