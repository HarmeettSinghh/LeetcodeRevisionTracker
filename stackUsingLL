// Stack class
class myStack {
    static class Node{
        int val;
        Node next;
        Node(int val){
            this.val = val;
            next = null;
        }
       
    }
    Node top;
    int size;
    public myStack() {
        // Initialize your data members
        top = null;
        size=0;
        
    }

    public boolean isEmpty() {
        // check if the stack is empty
        if(top==null){
            return true;
        }
        
        return false;
    }

    public void push(int x) {
        // Adds an element x at the rear of the stack.
        Node newNode = new Node(x);
        newNode.next = top;
        top = newNode;
        size++;
    }

    public void pop() {
        // Removes the front element of the stack.
        if(isEmpty()){
            return;
        }
        size--;
        top = top.next;
    }

    public int peek() {
        // Returns the front element of the stack.
        // If stack is empty, return -1.
        if(isEmpty()){
            return -1;
        }
        return top.val;
    }

    public int size() {
        // Returns the current size of the stack.
        if(isEmpty()){
            return 0;
        }
        return size;
    }
}
